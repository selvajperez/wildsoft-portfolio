---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import NoteRow from '../components/NoteRow.astro';
import { site } from '../data/site';

const projects = (await getCollection('portfolio')).sort((a, b) => a.data.order - b.data.order);
const notes = (await getCollection('notas'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<BaseLayout title="WildSoft — Data & Wilderness">
  <Header />

  <!-- hero -->
  <section style="padding: 74px 64px 66px; display: grid; grid-template-columns: 1.15fr 1fr; gap: 56px; align-items: center; animation: wsFade 0.7s ease both;">
    <div>
      <div class="mono" style="font-size: 12px; letter-spacing: 0.22em; color: var(--green-label); margin-bottom: 26px;">44.2601° N — CAMPO ABIERTO / FIELD NOTES</div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 76px; line-height: 1.02; letter-spacing: -0.01em; margin: 0 0 24px;">En lo salvaje se preserva el mundo.</h1>
      <p style="font-family: 'Spectral', serif; font-style: italic; font-size: 21px; color: var(--green); max-width: 44ch; margin: 0 0 34px; line-height: 1.5;">{site.quote}</p>
      <p style="font-size: 18px; line-height: 1.75; max-width: 52ch; color: var(--ink-soft); margin: 0 0 38px;">Portfolio, notas y trabajo de análisis de datos hecho a la manera del naturalista: con paciencia, sin ruido y respetando el terreno.</p>
      <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
        <a href="/portfolio" style="background: var(--ink); color: var(--bg); text-decoration: none; padding: 15px 30px; border-radius: 999px; font-size: 15px; letter-spacing: 0.02em;">Ver el portfolio →</a>
        <a href="/notas" style="color: var(--ink); text-decoration: none; padding: 15px 6px; font-size: 15px; border-bottom: 1px solid var(--accent);">Leer las notas</a>
      </div>
    </div>
    <div style="position: relative;">
      <img src="/images/hero-thoreau.webp" alt="En lo salvaje se preserva el mundo" style="display: block; width: 520px; max-width: 100%; height: 520px; object-fit: cover; border-radius: 10px; box-shadow: 0 20px 50px rgba(20,38,30,0.22);" />
      <div class="mono" style="position: absolute; left: 0; bottom: -30px; font-size: 11px; letter-spacing: 0.12em; color: var(--muted);">// in wildness — Walden Woods</div>
    </div>
  </section>

  <!-- portfolio -->
  <section class="section">
    <div style="display: flex; align-items: baseline; justify-content: space-between; border-top: 1px solid var(--border); padding-top: 30px; margin-bottom: 40px; flex-wrap: wrap; gap: 12px;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 40px; margin: 0;">Portfolio <span class="mono" style="font-size: 13px; color: var(--muted); letter-spacing: 0.1em;">/ SELECTED WORK</span></h2>
      <a href="/portfolio" class="mono" style="font-size: 13px; color: var(--muted); text-decoration: none;">01 — {String(projects.length).padStart(2, '0')} →</a>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 34px;">
      {projects.map((project) => (
        <PortfolioCard
          slug={project.slug}
          title={project.data.title}
          category={project.data.category}
          summary={project.data.summary}
          image={project.data.image}
          order={project.data.order}
        />
      ))}
    </div>
  </section>

  <!-- notas -->
  <section class="section">
    <div style="display: flex; align-items: baseline; justify-content: space-between; border-top: 1px solid var(--border); padding-top: 30px; margin-bottom: 34px; flex-wrap: wrap; gap: 12px;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 40px; margin: 0;">Notas <span class="mono" style="font-size: 13px; color: var(--muted); letter-spacing: 0.1em;">/ FIELD NOTES</span></h2>
      <a href="/notas" class="mono" style="font-size: 13px; color: var(--muted); text-decoration: none;">Ver todas →</a>
    </div>
    <div style="display: flex; flex-direction: column;">
      {notes.map((note) => (
        <NoteRow slug={note.slug} title={note.data.title} date={note.data.date} excerpt={note.data.excerpt} />
      ))}
    </div>
  </section>

  <!-- sobre mí -->
  <section id="sobre-mi" class="section">
    <div style="border-top: 1px solid var(--border); padding-top: 44px; display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; align-items: start;">
      <div>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 40px; margin: 0 0 22px;">Sobre mí <span class="mono" style="font-size: 13px; color: var(--muted); letter-spacing: 0.1em;">/ ABOUT</span></h2>
        <p style="font-size: 18px; line-height: 1.75; color: var(--ink-soft); margin: 0 0 18px; max-width: 52ch;">WildSoft es un estudio de datos de una sola persona. Trabajo la inteligencia de negocio como quien recorre un bosque: observando primero, midiendo con cuidado y dejando el terreno mejor de como lo encontré.</p>
        <p style="font-size: 18px; line-height: 1.75; color: var(--ink-soft); margin: 0; max-width: 52ch;">Creo en la simplicidad, en el dato honesto y en el trabajo no comercial que respeta a quien lo lee. Este sitio recoge mis proyectos y mis notas de campo.</p>
      </div>
      <div style="background: var(--ink); color: var(--bg); border-radius: 8px; padding: 30px 30px 34px;">
        <div class="mono" style="font-size: 11px; letter-spacing: 0.18em; color: #9CB87A; margin-bottom: 18px;">CONTACTO / CONTACT</div>
        <p style="font-family: 'Cormorant Garamond', serif; font-size: 26px; margin: 0 0 6px;"><a href={`mailto:${site.email}`} style="color: inherit; text-decoration: none;">{site.email}</a></p>
        <p style="font-size: 15px; color: #cdd8bf; margin: 0 0 22px;">Disponible para proyectos de análisis y visualización de datos.</p>
        <div style="display: flex; gap: 18px; font-size: 13px;" class="mono">
          <a href={site.linkedin} style="color: var(--bg); text-decoration: none; border-bottom: 1px solid var(--accent);">LinkedIn</a>
          <a href={site.github} style="color: var(--bg); text-decoration: none; border-bottom: 1px solid var(--accent);">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
